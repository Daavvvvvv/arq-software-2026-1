# ── Base de datos ─────────────────────────────────────────
# Railway provee DATABASE_URL automáticamente en producción
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/concert_orders
DB_WRITE_HOST=localhost
DB_READ_HOST=localhost
DB_PORT=5432
DB_NAME=concert_orders
DB_USER=postgres
DB_PASS=postgres

# ── Redis ─────────────────────────────────────────────────
# Railway provee REDIS_URL automáticamente en producción
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── RabbitMQ ──────────────────────────────────────────────
# Local: user/password definidos en docker-compose
RABBITMQ_URL=amqp://user:password@localhost:5672
# Railway/CloudAMQP (Lemur free tier):
# RABBITMQ_URL=amqps://user:pass@host.cloudamqp.com/vhost

# ── JWT ───────────────────────────────────────────────────
JWT_MODE=local
JWT_SECRET=dev_secret_change_in_prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Edge ──────────────────────────────────────────────────
THROTTLE_ENABLED=true
CDN_BASE_URL=http://localhost:3001/public

# ── Cloudflare R2 (reemplaza S3) ──────────────────────────
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=concert-orders-assets

# ── Pagos ─────────────────────────────────────────────────
PAYMENT_PROVIDER=mock
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Notificaciones ────────────────────────────────────────
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=
EMAIL_PROVIDER=ethereal
SENDGRID_API_KEY=

# ── App ───────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173
# ── Observabilidad ────────────────────
# Nombre del servicio (sobreescribe el default por app)
# SERVICE_NAME=order-processor

# OpenTelemetry → Grafana Tempo
# Local: apunta al contenedor tempo en docker-compose
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Grafana Cloud Tempo:
# OTEL_EXPORTER_OTLP_ENDPOINT=https://tempo-prod-XX.grafana.net/tempo
# OTEL_EXPORTER_OTLP_HEADERS={"Authorization":"Basic <base64(instanceId:token)>"}

# Logs → Grafana Loki
# Local: apunta al contenedor loki en docker-compose
LOKI_URL=http://localhost:3100
# Grafana Cloud Loki:
# LOKI_URL=https://logs-prod-XX.grafana.net
# LOKI_USER=<instanceId>
# LOKI_TOKEN=<grafana-cloud-api-token>
