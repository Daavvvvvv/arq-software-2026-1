# ── Base de datos ─────────────────────────
DB_WRITE_HOST=localhost
DB_READ_HOST=localhost
DB_PORT=5432
DB_NAME=concert_orders
DB_USER=postgres
DB_PASS=postgres

# ── Redis ────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ──────────────────────────────────
JWT_MODE=local
JWT_SECRET=dev_secret_change_in_prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COGNITO_USER_POOL_ID=
COGNITO_REGION=us-east-1

# ── Edge ─────────────────────────────────
THROTTLE_ENABLED=true
CDN_BASE_URL=http://localhost:3001/public

# ── AWS / LocalStack ──────────────────────
AWS_REGION=us-east-1
AWS_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── SNS ARNs ─────────────────────────────
SNS_ORDER_EVENTS_ARN=arn:aws:sns:us-east-1:000000000000:order-events
SNS_PAYMENT_EVENTS_ARN=arn:aws:sns:us-east-1:000000000000:payment-events
SNS_KITCHEN_EVENTS_ARN=arn:aws:sns:us-east-1:000000000000:kitchen-events
SNS_DELIVERY_EVENTS_ARN=arn:aws:sns:us-east-1:000000000000:delivery-events
SNS_NOTIFICATION_ARN=arn:aws:sns:us-east-1:000000000000:notification-topic

# ── SQS Queue URLs ───────────────────────
SQS_PAYMENT_QUEUE_URL=http://localhost:4566/000000000000/payment-queue
SQS_KITCHEN_QUEUE_URL=http://localhost:4566/000000000000/kitchen-queue
SQS_DELIVERY_QUEUE_URL=http://localhost:4566/000000000000/delivery-queue
SQS_NOTIFICATION_QUEUE_URL=http://localhost:4566/000000000000/notification-queue
SQS_DLQ_MONITOR_URL=http://localhost:4566/000000000000/dlq-monitor-queue

# ── Pagos ─────────────────────────────────
PAYMENT_PROVIDER=mock
MERCADOPAGO_ACCESS_TOKEN=TEST-...
MERCADOPAGO_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Notificaciones ────────────────────────
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=
EMAIL_PROVIDER=ethereal
SENDGRID_API_KEY=

# ── App ───────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173
